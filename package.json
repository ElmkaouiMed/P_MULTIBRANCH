{
  "name": "multibranch-template",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});require('fs').rmSync('node_modules/.cache',{recursive:true,force:true})\"",
    "prebuild": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "build": "node -e \"const{execSync}=require('child_process');const f=()=>{try{execSync('next build',{stdio:'inherit',shell:true})}catch(e){console.log('Build failed, retrying...');require('fs').rmSync('.next',{recursive:true,force:true});f()}};f()\"",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.5.19",
    "react": "^19.0.7",
    "react-dom": "^19.0.7",
    "next-intl": "^4.13.1",
    "framer-motion": "^12.9.4",
    "lucide-react": "^0.468.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.19"
  }
}
